default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :build_and_upload do
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "AuthKey.p8",
      in_house: false
    )

    # Try to find or create the app
    begin
      app = Spaceship::ConnectAPI::App.find("com.neilross.testapp")
      if app
        UI.success("Found existing app: #{app.name}")
      else
        UI.important("App not found, creating...")
        app = Spaceship::ConnectAPI::App.create(
          name: "TestApp",
          bundle_id: "com.neilross.testapp",
          platforms: [Spaceship::ConnectAPI::Platform::IOS],
          primary_locale: "en-US"
        )
        UI.success("Created app: #{app.name}")
      end
    rescue => e
      UI.error("Failed to find/create app: #{e.message}")
      UI.error("Please create the app manually at https://appstoreconnect.apple.com")
      raise
    end

    # Build the app with automatic signing
    build_app(
      workspace: "App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      team_id: ENV["ASC_TEAM_ID"],
      xcargs: "-allowProvisioningUpdates",
      skip_package_pkg: true,
      output_directory: "build",
      output_name: "TestApp.ipa"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )
  end
end
