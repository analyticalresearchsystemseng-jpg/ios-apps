default_platform(:ios)

platform :ios do
  desc "Build the iOS app (compilation check)"
  lane :build do
    # Build for simulator - no signing needed
    build_app(
      workspace: "App/App.xcworkspace",
      scheme: "App",
      destination: "platform=iOS Simulator,name=iPhone 16",
      skip_package_ipa: true,
      skip_archive: true,
      skip_codesigning: true,
      xcargs: "CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO",
      output_directory: "build",
      output_name: "TestApp"
    )

    UI.success("✅ Build succeeded! App compiles correctly.")
    UI.important("")
    UI.important("For TestFlight upload, you need to:")
    UI.important("1. Register 'com.neilross.testapp' in App Store Connect")
    UI.important("2. Run: fastlane match appstore")
    UI.important("3. Set ENABLE_TESTFLIGHT=true in GitHub secrets")
    UI.important("4. Trigger build_and_upload lane")
  end

  desc "Build and upload to TestFlight (requires app registration)"
  lane :build_and_upload do
    # Check if TestFlight is enabled
    unless ENV["ENABLE_TESTFLIGHT"] == "true"
      UI.error("TestFlight not enabled. Set ENABLE_TESTFLIGHT=true in GitHub secrets")
      UI.error("Also ensure com.neilross.testapp is registered in App Store Connect")
      exit(1)
    end

    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "AuthKey.p8",
      in_house: false
    )

    # Update project team
    update_project_team(
      path: "App/App.xcodeproj",
      teamid: ENV["ASC_TEAM_ID"]
    )

    # Enable automatic signing
    update_code_signing_settings(
      path: "App/App.xcodeproj",
      use_automatic_signing: true,
      team_id: ENV["ASC_TEAM_ID"],
      bundle_identifier: "com.neilross.testapp",
      code_sign_identity: "iPhone Distribution"
    )

    # Build the app
    build_app(
      workspace: "App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      export_team_id: ENV["ASC_TEAM_ID"],
      xcargs: "-allowProvisioningUpdates",
      output_directory: "build",
      output_name: "TestApp.ipa"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )

    UI.success("🚀 Uploaded to TestFlight!")
  end
end
