default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :build_and_upload do
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "AuthKey.p8",
      in_house: false
    )

    # For now, build without signing to verify the pipeline works
    # TODO: Add match or manual signing for TestFlight upload
    build_app(
      project: "App/App.xcodeproj",
      scheme: "App",
      destination: "platform=iOS Simulator,name=iPhone 16",
      skip_package_ipa: true,
      skip_archive: true,
      skip_codesigning: true,
      xcargs: "CODE_SIGNING_REQUIRED=NO CODE_SIGNING_ALLOWED=NO",
      output_directory: "build",
      output_name: "TestApp"
    )

    UI.success("Build succeeded! Signing and upload skipped.")
    UI.important("To enable TestFlight upload:")
    UI.important("1. Run: fastlane match appstore")
    UI.important("2. Remove skip_codesigning and destination from build_app")
    UI.important("3. Add: upload_to_testflight(api_key: api_key)")
  end
end
