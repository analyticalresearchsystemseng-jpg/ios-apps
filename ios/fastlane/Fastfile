default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :build_and_upload do
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "AuthKey.p8",
      in_house: false
    )

    # Update code signing settings
    update_code_signing_settings(
      path: "App/App.xcodeproj",
      use_automatic_signing: false,
      team_id: ENV["ASC_TEAM_ID"],
      bundle_identifier: "com.neilross.testapp",
      code_sign_identity: "iPhone Distribution",
      profile_name: "match AppStore com.neilross.testapp"
    )

    # Build the app (skip signing for now)
    build_app(
      project: "App/App.xcodeproj",
      scheme: "App",
      export_method: "app-store",
      export_team_id: ENV["ASC_TEAM_ID"],
      xcargs: "-allowProvisioningUpdates",
      skip_package_ipa: true,
      skip_codesigning: true,
      output_directory: "build",
      output_name: "TestApp.ipa"
    )

    # Note: For TestFlight upload, you need:
    # 1. App identifier registered in Apple Developer Portal
    # 2. Provisioning profiles created
    # 3. Match or manual signing setup
    # 
    # To enable upload, remove skip_codesigning and set up match:
    # match(type: "appstore", api_key: api_key)
    #
    # Then upload_to_testflight(api_key: api_key, ...)
  end
end
