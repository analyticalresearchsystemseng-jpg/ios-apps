default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :build_and_upload do
    # Set up App Store Connect API key
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: "AuthKey.p8",
      in_house: false
    )

    # Update project team
    update_project_team(
      path: "App/App.xcodeproj",
      teamid: ENV["ASC_TEAM_ID"]
    )

    # Register the app identifier if it doesn't exist
    produce(
      api_key: api_key,
      app_identifier: "com.neilross.testapp",
      app_name: "TestApp",
      sku: "testapp2026",
      team_id: ENV["ASC_TEAM_ID"],
      skip_itc: false
    )

    # Get provisioning profile via sigh
    sigh(
      api_key: api_key,
      app_identifier: "com.neilross.testapp",
      provisioning_name: "TestApp AppStore",
      filename: "TestApp.mobileprovision",
      force: true
    )

    # Build the app
    build_app(
      workspace: "App/App.xcworkspace",
      scheme: "App",
      export_method: "app-store",
      export_team_id: ENV["ASC_TEAM_ID"],
      export_options: {
        provisioningProfiles: {
          "com.neilross.testapp" => "TestApp AppStore"
        }
      },
      xcargs: "-allowProvisioningUpdates",
      output_directory: "build",
      output_name: "TestApp.ipa"
    )

    # Upload to TestFlight
    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true,
      notify_external_testers: false
    )
  end
end
